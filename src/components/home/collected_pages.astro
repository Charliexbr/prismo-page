---
import collected_pages from "../../collections/collected_pages.json";
import Button from "../button.astro";
import Collected_Page from "../collected_page.astro";
---

<section class="max-w-4xl mx-auto px-7 lg:px-0">
  <h2
    class="text-2xl font-bold leading-10 tracking-tight text-neutral-900 dark:text-neutral-100"
  >
  Charlie's Depot
  </h2>
  <p class="mb-6 text-base text-neutral-600 dark:text-neutral-400">
    Here are some unique websites...
  </p> 
  <div
    class="grid items-stretch w-full sm:grid-cols-2 md:grid-cols-3 gap-7 mt-7"
  >
    {
      collected_pages.map((collected_page) => {
        return (
          <Collected_Page
            name={collected_page.name}
            description={collected_page.description}
            image={collected_page.image}
            url={collected_page.url}
          />
        )
      })
    }
  </div>

  <div class="flex items-center justify-center w-full py-5">
    <Button text="View All My Collections" link="/collected_pages" />
  </div>
</section>
